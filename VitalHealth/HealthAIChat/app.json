{
"expo": {
"name": "VitalHealth",
"slug": "vitalhealth",
"version": "1.0.0",
"orientation": "portrait",
"icon": "./assets/icon.png",
"scheme": "vitalhealth",
"userInterfaceStyle": "automatic",

"assetBundlePatterns": [
  "**/*"
],

"plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  ],
  "@react-native-community/datetimepicker",
  "expo-asset",
  "expo-sqlite",
  "react-native-vision-camera"
],

"ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.monish.vitalhealth",
  "infoPlist": {
    "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera"
  }
},

"android": {
  "package": "com.monish.vitalhealth",
  "versionCode": 1,
  "permissions": [
    "CAMERA"
  ],
  "adaptiveIcon": {
  "foregroundImage": "./assets/icon.png",
  "backgroundColor": "#E6F4FE"
}
},

"experiments": {
  "typedRoutes": true
},

"androidStatusBar": {
  "backgroundColor": "#ffffff"
}

}
}